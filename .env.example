PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/ais_concepts
JWT_SECRET=change-this-to-a-long-random-string-in-production
# CORS: browser origins allowed to call this API (comma-separated). Required when the frontend is on another domain.
# Production example:
# CLIENT_ORIGIN=https://aisconcepts.netlify.app
# Local frontend (e.g. Live Server :5500) + local API (:3000):
# CLIENT_ORIGIN=http://localhost:5500,http://localhost:3000
CLIENT_ORIGIN=https://aisconcepts.netlify.app,http://localhost:3000
