PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/ais_concepts
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Default admin (synced into MongoDB on every server start — set ADMIN_PASSWORD in production)
ADMIN_EMAIL=admin@aisconcepts.com
ADMIN_USERNAME=aisconcepts
ADMIN_PASSWORD=#Aisconcepts16
# CORS: browser origins allowed to call this API (comma-separated).
CLIENT_ORIGIN=https://aisconcepts.com,https://ais-concepts.netlify.app,https://ais-concepts-fronted.vercel.app,http://localhost:3000
# Cloudinary (required for /api/upload-image — set these on Render as well)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
